<?xml version="1.0"?>
<robot name="user_kuka">
  <link name="base_link"/>
  <link name="link1"/>
  <link name="link2"/>
  <link name="link3"/>
  <link name="link4"/>
  <link name="link5"/>
  <link name="link6"/>
  <link name="link7"/>
  <link name="ee_link"/>

  <joint name="robot0/joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.97" upper="2.97" effort="50.0" velocity="2.0"/>
  </joint>
  <joint name="robot0/joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.09" upper="2.09" effort="50.0" velocity="2.0"/>
  </joint>
  <joint name="robot0/joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.97" upper="2.97" effort="50.0" velocity="2.0"/>
  </joint>
  <joint name="robot0/joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.09" upper="2.09" effort="50.0" velocity="2.0"/>
  </joint>
  <joint name="robot0/joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.97" upper="2.97" effort="50.0" velocity="2.0"/>
  </joint>
  <joint name="robot0/joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.09" upper="2.09" effort="50.0" velocity="2.0"/>
  </joint>
  <joint name="robot0/joint7" type="revolute">
    <parent link="link6"/>
    <child link="link7"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.05" upper="3.05" effort="50.0" velocity="2.0"/>
  </joint>

  <joint name="ee_fixed" type="fixed">
    <parent link="link7"/>
    <child link="ee_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
</robot>

