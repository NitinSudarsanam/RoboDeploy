<mujoco model="franka_basic">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <joint damping="2.0" armature="0.05" frictionloss="0.1"/>
    <geom friction="0.7 0.02 0.001" rgba="0.7 0.7 0.7 1"/>
  </default>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.9 0.9 0.9 1"/>

    <camera name="base_cam" pos="1.2 -0.9 0.9" xyaxes="0.7 0.7 0 -0.2 0.2 0.95"/>

    <body name="table" pos="0.55 0.0 0.35">
      <geom type="box" size="0.45 0.35 0.03" rgba="0.6 0.45 0.3 1"/>
    </body>

    <body name="pick_cube" pos="0.55 0.0 0.43">
      <freejoint name="pick_cube_joint"/>
      <geom type="box" size="0.02 0.02 0.02" mass="0.05" rgba="0.8 0.1 0.1 1"/>
    </body>

    <site name="pick_target" pos="0.55 0.0 0.43" size="0.015" rgba="0.1 0.8 0.1 1"/>

    <body name="robot0/base" pos="0.0 0.0 0.4">
      <geom type="cylinder" size="0.08 0.05" rgba="0.2 0.2 0.2 1"/>

      <body name="robot0/link1" pos="0 0 0.05">
        <joint name="robot0/joint1" type="hinge" axis="0 0 1" range="-2.9 2.9"/>
        <geom type="capsule" fromto="0 0 0 0 0 0.2" size="0.04"/>

        <body name="robot0/link2" pos="0 0 0.2">
          <joint name="robot0/joint2" type="hinge" axis="0 1 0" range="-1.8 1.8"/>
          <geom type="capsule" fromto="0 0 0 0 0 0.2" size="0.035"/>

          <body name="robot0/link3" pos="0 0 0.2">
            <joint name="robot0/joint3" type="hinge" axis="0 1 0" range="-2.9 2.9"/>
            <geom type="capsule" fromto="0 0 0 0 0 0.2" size="0.03"/>

            <body name="robot0/link4" pos="0 0 0.2">
              <joint name="robot0/joint4" type="hinge" axis="1 0 0" range="-3.0 0.0"/>
              <geom type="capsule" fromto="0 0 0 0 0 0.15" size="0.028"/>

              <body name="robot0/link5" pos="0 0 0.15">
                <joint name="robot0/joint5" type="hinge" axis="0 1 0" range="-2.9 2.9"/>
                <geom type="capsule" fromto="0 0 0 0 0 0.12" size="0.025"/>

                <body name="robot0/link6" pos="0 0 0.12">
                  <joint name="robot0/joint6" type="hinge" axis="1 0 0" range="-0.1 3.7"/>
                  <geom type="capsule" fromto="0 0 0 0 0 0.1" size="0.022"/>

                  <body name="robot0/link7" pos="0 0 0.1">
                    <joint name="robot0/joint7" type="hinge" axis="0 1 0" range="-2.9 2.9"/>
                    <geom type="capsule" fromto="0 0 0 0 0 0.08" size="0.02"/>

                    <body name="robot0/ee_link" pos="0 0 0.1">
                      <geom type="sphere" size="0.025" rgba="0.1 0.1 0.1 1"/>
                      <camera name="eye_in_hand" pos="0.0 0.0 0.03" quat="0.707 0.707 0 0"/>

                      <body name="robot0/left_finger" pos="0 0.03 0">
                        <joint name="robot0/finger_left" type="slide" axis="0 1 0" range="0 0.04"/>
                        <geom type="box" size="0.01 0.005 0.03" rgba="0.3 0.3 0.3 1"/>
                      </body>
                      <body name="robot0/right_finger" pos="0 -0.03 0">
                        <joint name="robot0/finger_right" type="slide" axis="0 -1 0" range="0 0.04"/>
                        <geom type="box" size="0.01 0.005 0.03" rgba="0.3 0.3 0.3 1"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="robot0/act1" joint="robot0/joint1" kp="150" ctrlrange="-2.9 2.9"/>
    <position name="robot0/act2" joint="robot0/joint2" kp="150" ctrlrange="-1.8 1.8"/>
    <position name="robot0/act3" joint="robot0/joint3" kp="150" ctrlrange="-2.9 2.9"/>
    <position name="robot0/act4" joint="robot0/joint4" kp="150" ctrlrange="-3.0 0.0"/>
    <position name="robot0/act5" joint="robot0/joint5" kp="100" ctrlrange="-2.9 2.9"/>
    <position name="robot0/act6" joint="robot0/joint6" kp="80" ctrlrange="-0.1 3.7"/>
    <position name="robot0/act7" joint="robot0/joint7" kp="80" ctrlrange="-2.9 2.9"/>
    <position name="robot0/grip_left" joint="robot0/finger_left" kp="300" ctrlrange="0 0.04"/>
    <position name="robot0/grip_right" joint="robot0/finger_right" kp="300" ctrlrange="0 0.04"/>
  </actuator>
</mujoco>
