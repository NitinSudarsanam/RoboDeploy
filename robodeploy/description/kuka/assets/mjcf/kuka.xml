<mujoco model="kuka_basic">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <joint damping="2.0" armature="0.05" frictionloss="0.1"/>
    <geom friction="0.7 0.02 0.001" rgba="0.75 0.75 0.75 1"/>
  </default>

  <worldbody>
    <body name="robot0/base" pos="0.0 0.0 0.4">
      <geom type="cylinder" size="0.09 0.06" rgba="0.2 0.2 0.2 1"/>

      <body name="robot0/link1" pos="0 0 0.06">
        <joint name="robot0/joint1" type="hinge" axis="0 0 1" range="-2.97 2.97"/>
        <geom type="capsule" fromto="0 0 0 0 0 0.18" size="0.04"/>

        <body name="robot0/link2" pos="0 0 0.18">
          <joint name="robot0/joint2" type="hinge" axis="0 1 0" range="-2.09 2.09"/>
          <geom type="capsule" fromto="0 0 0 0 0 0.2" size="0.038"/>

          <body name="robot0/link3" pos="0 0 0.2">
            <joint name="robot0/joint3" type="hinge" axis="0 1 0" range="-2.97 2.97"/>
            <geom type="capsule" fromto="0 0 0 0 0 0.2" size="0.034"/>

            <body name="robot0/link4" pos="0 0 0.2">
              <joint name="robot0/joint4" type="hinge" axis="1 0 0" range="-2.09 2.09"/>
              <geom type="capsule" fromto="0 0 0 0 0 0.17" size="0.03"/>

              <body name="robot0/link5" pos="0 0 0.17">
                <joint name="robot0/joint5" type="hinge" axis="0 1 0" range="-2.97 2.97"/>
                <geom type="capsule" fromto="0 0 0 0 0 0.14" size="0.027"/>

                <body name="robot0/link6" pos="0 0 0.14">
                  <joint name="robot0/joint6" type="hinge" axis="1 0 0" range="-2.09 2.09"/>
                  <geom type="capsule" fromto="0 0 0 0 0 0.12" size="0.024"/>

                  <body name="robot0/link7" pos="0 0 0.12">
                    <joint name="robot0/joint7" type="hinge" axis="0 1 0" range="-3.05 3.05"/>
                    <geom type="capsule" fromto="0 0 0 0 0 0.1" size="0.022"/>

                    <body name="robot0/ee_link" pos="0 0 0.1">
                      <geom type="sphere" size="0.025" rgba="0.1 0.1 0.1 1"/>
                      <camera name="eye_in_hand" pos="0.0 0.0 0.03" quat="0.707 0.707 0 0"/>

                      <body name="robot0/left_finger" pos="0 0.03 0">
                        <joint name="robot0/finger_left" type="slide" axis="0 1 0" range="0 0.04"/>
                        <geom type="box" size="0.01 0.005 0.03" rgba="0.3 0.3 0.3 1"/>
                      </body>
                      <body name="robot0/right_finger" pos="0 -0.03 0">
                        <joint name="robot0/finger_right" type="slide" axis="0 -1 0" range="0 0.04"/>
                        <geom type="box" size="0.01 0.005 0.03" rgba="0.3 0.3 0.3 1"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="robot0/act1" joint="robot0/joint1" kp="150" ctrlrange="-2.97 2.97"/>
    <position name="robot0/act2" joint="robot0/joint2" kp="140" ctrlrange="-2.09 2.09"/>
    <position name="robot0/act3" joint="robot0/joint3" kp="130" ctrlrange="-2.97 2.97"/>
    <position name="robot0/act4" joint="robot0/joint4" kp="110" ctrlrange="-2.09 2.09"/>
    <position name="robot0/act5" joint="robot0/joint5" kp="90" ctrlrange="-2.97 2.97"/>
    <position name="robot0/act6" joint="robot0/joint6" kp="80" ctrlrange="-2.09 2.09"/>
    <position name="robot0/act7" joint="robot0/joint7" kp="70" ctrlrange="-3.05 3.05"/>
    <position name="robot0/grip_left" joint="robot0/finger_left" kp="300" ctrlrange="0 0.04"/>
    <position name="robot0/grip_right" joint="robot0/finger_right" kp="300" ctrlrange="0 0.04"/>
  </actuator>
</mujoco>
