<?xml version="1.0"?>
<!-- Placeholder SO-101 follower kinematics for RoboDeploy. Replace with the official URDF when available. -->
<robot name="so101">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.10 0.04"/>
      </geometry>
      <material name="base_gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.10 0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="shoulder_pan" type="revolute">
    <parent link="base_link"/>
    <child link="link_shoulder"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <limit lower="-2.6" upper="2.6" effort="10" velocity="3"/>
  </joint>
  <link name="link_shoulder">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.08"/>
      </geometry>
      <material name="link_blue">
        <color rgba="0.2 0.3 0.9 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.08"/>
      </geometry>
    </collision>
  </link>

  <joint name="shoulder_lift" type="revolute">
    <parent link="link_shoulder"/>
    <child link="link_upper"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <limit lower="-2.6" upper="2.6" effort="10" velocity="3"/>
  </joint>
  <link name="link_upper">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.020" length="0.12"/>
      </geometry>
      <material name="link_green">
        <color rgba="0.2 0.8 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.020" length="0.12"/>
      </geometry>
    </collision>
  </link>

  <joint name="elbow_flex" type="revolute">
    <parent link="link_upper"/>
    <child link="link_fore"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <limit lower="-2.6" upper="2.6" effort="10" velocity="3"/>
  </joint>
  <link name="link_fore">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.0008" ixy="0.0" ixz="0.0" iyy="0.0008" iyz="0.0" izz="0.0008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.10"/>
      </geometry>
      <material name="link_orange">
        <color rgba="0.9 0.5 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.10"/>
      </geometry>
    </collision>
  </link>

  <joint name="wrist_flex" type="revolute">
    <parent link="link_fore"/>
    <child link="link_wrist_pitch"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <limit lower="-2.6" upper="2.6" effort="10" velocity="3"/>
  </joint>
  <link name="link_wrist_pitch">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.016" length="0.06"/>
      </geometry>
      <material name="link_purple">
        <color rgba="0.6 0.3 0.7 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.016" length="0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="wrist_roll" type="revolute">
    <parent link="link_wrist_pitch"/>
    <child link="link_wrist_roll"/>
    <axis xyz="1 0 0"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <limit lower="-2.6" upper="2.6" effort="10" velocity="3"/>
  </joint>
  <link name="link_wrist_roll">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.4"/>
      <inertia ixx="0.0004" ixy="0.0" ixz="0.0" iyy="0.0004" iyz="0.0" izz="0.0004"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.014" length="0.05"/>
      </geometry>
      <material name="link_red">
        <color rgba="0.85 0.25 0.25 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.014" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="gripper" type="revolute">
    <parent link="link_wrist_roll"/>
    <child link="gripper_link"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <limit lower="-0.2" upper="1.5" effort="5" velocity="2"/>
  </joint>
  <link name="gripper_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.06"/>
      </geometry>
      <material name="gripper_dark">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.06"/>
      </geometry>
    </collision>
  </link>
</robot>
